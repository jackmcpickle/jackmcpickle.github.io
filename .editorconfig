# EditorConfig is awesome: http://EditorConfig.org

root = true

[*]
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
charset = utf-8
quote_type = single

[*.astro]
quote_type = double

[*.yaml,*.yml]
indent_size = 2
quote_type = double


[*.md]
trim_trailing_whitespace = false
