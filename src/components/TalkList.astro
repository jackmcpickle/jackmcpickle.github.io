---
import { getSortedTalks } from '../lib/collections';
import MacWindow from './MacWindow.astro';
import TalkItem from './TalkItem.astro';

const talks = await getSortedTalks();
---

<MacWindow
    id="talks"
    title="Talks & Workshops"
    note="Conference talks, meetups, and workshops."
    offset="l"
    screenLabel="Talks window"
>
    <article class="flex flex-col gap-3">
        {talks.map((talk) => (
            <TalkItem talk={talk} />
        ))}
    </article>
</MacWindow>
