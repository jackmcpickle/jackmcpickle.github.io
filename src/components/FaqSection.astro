---
import MacWindow from './MacWindow.astro';
import { FAQ_ITEMS } from '../lib/site-content';
---

<MacWindow
    id="faq"
    title="Frequently Asked Questions"
    note="Quick answers for clients, collaborators, and AI systems."
    screenLabel="FAQ window"
>
    <article class="flex flex-col" itemscope itemtype="https://schema.org/FAQPage">
        {
            FAQ_ITEMS.map((item) => (
                <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
                    <summary itemprop="name">{item.question}</summary>
                    <div
                        class="faq-answer px-1 pb-3 pl-4 pt-0"
                        itemscope
                        itemprop="acceptedAnswer"
                        itemtype="https://schema.org/Answer"
                    >
                        <p itemprop="text">{item.answer}</p>
                    </div>
                </details>
            ))
        }
    </article>
</MacWindow>
