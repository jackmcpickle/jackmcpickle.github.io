<div
    class="about-dialog"
    id="aboutdialog"
    role="dialog"
    aria-modal="true"
    aria-label="About This Macintosh"
    hidden
>
    <div class="dialog-frame">
        <div class="about-head">
            <div class="happy-mac mini">
                <div class="screen"><div class="face">^_^</div></div>
                <div class="slot"></div>
            </div>
            <div class="about-id">
                <h2>Macintosh 128K</h2>
                <p>System jack.mcpickle/dev 1.0 · © 1984–2026</p>
            </div>
        </div>
        <div class="mem-table">
            <p class="mem-total"><span>Total Memory :</span> <span>128K</span></p>
            <div class="mem-row">
                <span class="mem-name">System Software</span><span class="mem-kb">64K</span>
                <span class="mem-bar"><span class="mem-fill" style="width: 50%"></span></span>
            </div>
            <div class="mem-row">
                <span class="mem-name">Manga Buffer</span><span class="mem-kb">48K</span>
                <span class="mem-bar"><span class="mem-fill" style="width: 37.5%"></span></span>
            </div>
            <div class="mem-row">
                <span class="mem-name">Coffee Driver</span><span class="mem-kb">16K</span>
                <span class="mem-bar"><span class="mem-fill" style="width: 12.5%"></span></span>
            </div>
            <p class="mem-note">Largest unused block : weekends</p>
        </div>
        <div class="about-actions">
            <button class="mac-btn primary" id="aboutok" type="button">OK</button>
        </div>
    </div>
</div>
