---
import { getSortedProjects } from '../lib/collections';
import MacWindow from './MacWindow.astro';
import ProjectItem from './ProjectItem.astro';

const projects = await getSortedProjects();
---

<MacWindow
    id="work"
    title="Selected Work"
    note="Product strategy, platform architecture, and hands-on delivery."
    screenLabel="Selected work window"
>
    <article class="finder-list">
        <div
            class="finder-head grid grid-cols-[minmax(130px,1.3fr)_minmax(0,1.1fr)_minmax(0,1.5fr)] items-baseline gap-3 px-3 py-1.5 @max-[530px]/crt:grid-cols-2"
        >
            <span>Name</span><span>Location</span><span>Kind</span>
        </div>
        {projects.map((project) => (
            <ProjectItem project={project} />
        ))}
    </article>
</MacWindow>
