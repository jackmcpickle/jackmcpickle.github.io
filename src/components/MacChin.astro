<div class="mac-chin">
    <div class="chin-id">
        <svg class="badge-apple" viewBox="0 0 13 15" aria-hidden="true">
            <clipPath id="appleclip">
                <path
                    d="M7 0h2v2H7zM5 1h2v2H5zM2 4h4v1h2V4h4v8h-1v2H3v-2H2V4zM0 6h2v4H0zM11 6h2v4h-2z"
                ></path>
            </clipPath>
            <g clip-path="url(#appleclip)">
                <rect x="0" y="0" width="13" height="3.4" fill="#5fb04c"></rect>
                <rect x="0" y="3.4" width="13" height="2.4" fill="#f4b400"></rect>
                <rect x="0" y="5.8" width="13" height="2.4" fill="#e8772e"></rect>
                <rect x="0" y="8.2" width="13" height="2.4" fill="#d9412b"></rect>
                <rect x="0" y="10.6" width="13" height="2.2" fill="#8e4a9e"></rect>
                <rect x="0" y="12.8" width="13" height="2.2" fill="#3d7dc4"></rect>
            </g>
        </svg>
        <span class="wordmark">Macintosh</span>
    </div>
    <span class="spacer"></span>
    <div class="floppy" aria-hidden="true"></div>
    <button
        class="power-btn"
        id="powerbtn"
        type="button"
        aria-label="Power on / off"
        aria-pressed="true"
    >
        <span class="led" aria-hidden="true"></span>
    </button>
</div>
