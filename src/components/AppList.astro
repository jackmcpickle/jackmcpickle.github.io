---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import MacWindow from './MacWindow.astro';
import AppItem from './AppItem.astro';

const apps = (await getCollection('apps')).sort(
    (a: CollectionEntry<'apps'>, b: CollectionEntry<'apps'>) => a.data.order - b.data.order,
);
---

<MacWindow
    id="apps"
    title="Recent Apps"
    note="Recent product builds — designed, architected, and shipped."
    offset="l"
    screenLabel="Recent apps window"
>
    <div class="app-grid">
        {apps.map((app) => (
            <AppItem app={app} />
        ))}
    </div>
</MacWindow>
