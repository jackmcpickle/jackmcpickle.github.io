---
import { getSortedApps } from '@/lib/collections';
import MacWindow from './MacWindow.astro';
import AppItem from './AppItem.astro';

const apps = await getSortedApps();
---

<MacWindow
    id="apps"
    title="Recent Apps"
    note="Recent product builds — designed, architected, and shipped."
    screenLabel="Recent apps window"
>
    <div class="grid grid-cols-[repeat(auto-fit,minmax(180px,1fr))] gap-4">
        {apps.map((app) => (
            <AppItem app={app} />
        ))}
    </div>
</MacWindow>
