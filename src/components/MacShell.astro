---
import MenuBar from './MenuBar.astro';
import AboutSection from './AboutSection.astro';
import AppList from './AppList.astro';
import ProjectList from './ProjectList.astro';
import TalkList from './TalkList.astro';
import ListeningList from './ListeningList.astro';
import AnimeList from './AnimeList.astro';
import SiteFooter from './SiteFooter.astro';
import BootScreen from './BootScreen.astro';
import AboutDialog from './AboutDialog.astro';
import MacChin from './MacChin.astro';
---

<div class="room">
    <div class="mac" data-screen-label="Macintosh 128K">
        <div class="bezel">
            <div class="crt">
                <div class="crt-content" id="crt">
                    <MenuBar />
                    <main class="desktop">
                        <AboutSection />
                        <AppList />
                        <ProjectList />
                        <TalkList />
                        <ListeningList />
                        <AnimeList />
                        <SiteFooter />
                    </main>
                </div>

                <AboutDialog />
                <BootScreen />

                <div class="scanlines" aria-hidden="true"></div>
                <div class="crt-vignette" aria-hidden="true"></div>
                <div class="crt-glare" aria-hidden="true"></div>
            </div>
        </div>

        <MacChin />
    </div>
</div>

<script src="../scripts/portfolio.js"></script>
