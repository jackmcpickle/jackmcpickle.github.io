---
import MenuBar from './MenuBar.astro';
import AboutSection from './AboutSection.astro';
import AboutPageSection from './AboutPageSection.astro';
import AppList from './AppList.astro';
import ProjectList from './ProjectList.astro';
import TalkList from './TalkList.astro';
import ListeningList from './ListeningList.astro';
import AnimeList from './AnimeList.astro';
import FaqSection from './FaqSection.astro';
import SiteFooter from './SiteFooter.astro';
import BootScreen from './BootScreen.astro';
import AboutDialog from './AboutDialog.astro';
import MacChin from './MacChin.astro';
import { crtSwap } from '@/lib/view-transitions';

interface Props {
    page?: 'home' | 'about';
}

const { page = 'home' } = Astro.props;
---

<div class="mac-shell grid h-full place-items-center px-2 py-[1.5dvh]">
    <div class="mac" data-screen-label="Macintosh 128K">
        <div class="bezel">
            <div class="crt">
                <div class="crt-content" id="crt">
                    <MenuBar />
                    <main
                        transition:name="crt-main"
                        transition:animate={crtSwap}
                        class="mx-auto flex max-w-[880px] flex-col gap-11 px-[clamp(14px,3cqw,24px)] pb-14 pt-9"
                    >
                        {page === 'home' ? (
                            <>
                                <AboutSection />
                                <AppList />
                                <ProjectList />
                                <TalkList />
                            </>
                        ) : (
                            <>
                                <AboutPageSection />
                                <ListeningList />
                                <AnimeList />
                                <FaqSection />
                            </>
                        )}
                        <SiteFooter />
                    </main>
                </div>

                <AboutDialog />
                <BootScreen />

                <div class="scanlines" aria-hidden="true"></div>
                <div class="crt-vignette" aria-hidden="true"></div>
                <div class="crt-glare" aria-hidden="true"></div>
            </div>
        </div>

        <MacChin />
    </div>
</div>

<script>
    import '@/scripts/portfolio/index.ts';
</script>
