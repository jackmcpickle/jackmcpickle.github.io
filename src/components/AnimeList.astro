---
import { getSortedAnime } from '@/lib/collections';
import MacWindow from './MacWindow.astro';
import AnimeItem from './AnimeItem.astro';

const items = await getSortedAnime();
---

<MacWindow
    id="manga"
    title="Manga Reading Log"
    note="Currently reading — all caught up to the latest chapter."
    screenLabel="Manga reading log window"
>
    <div class="flex flex-col">
        {items.map((item) => (
            <AnimeItem item={item} />
        ))}
    </div>
</MacWindow>
