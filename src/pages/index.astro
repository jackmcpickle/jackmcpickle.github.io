---
import { getSortedTalks } from '@/lib/collections';
import BaseLayout from '@/layouts/BaseLayout.astro';
import MacShell from '@/components/MacShell.astro';
import {
    organizationSchema,
    websiteSchema,
    personSchema,
    articleSchema,
} from '@/lib/structured-data';
import { HOME_PAGE, SITE_URL } from '@/lib/site-content';
import { resolveProfileImage } from '@/lib/profile-image';

const talks = await getSortedTalks();
const site = Astro.site ?? new URL(SITE_URL);
const profileImage = await resolveProfileImage(site);

const jsonLd = [
    organizationSchema(profileImage.url),
    websiteSchema,
    personSchema(profileImage.url),
    ...talks.map((talk) => articleSchema(talk.data, profileImage.url)),
];
---

<BaseLayout
    title={HOME_PAGE.title}
    description={HOME_PAGE.description}
    ogImage={profileImage.path}
    jsonLd={jsonLd}
>
    <MacShell />
</BaseLayout>
