---
import BaseLayout from '../layouts/BaseLayout.astro';
import MacShell from '../components/MacShell.astro';
import { organizationSchema, personSchema, faqPageSchema, FAQ_ITEMS } from '../lib/structured-data';
import { ABOUT_PAGE } from '../lib/site-content';
import { resolveProfileImage } from '../lib/profile-image';

const profileImage = await resolveProfileImage(Astro.site!);
const jsonLd = [
    organizationSchema(profileImage.url),
    personSchema(profileImage.url),
    faqPageSchema(FAQ_ITEMS),
];
---

<BaseLayout
    title={ABOUT_PAGE.title}
    description={ABOUT_PAGE.description}
    ogImage={profileImage.path}
    jsonLd={jsonLd}
>
    <MacShell page="about" />
</BaseLayout>
